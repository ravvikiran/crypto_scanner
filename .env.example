# Crypto Scanner Configuration (v2.0 Enhanced)
# Copy this file to .env and fill in your API keys

# ==========================================
# TELEGRAM ALERTS (Required for notifications)
# ==========================================
# Create a bot: @BotFather on Telegram
# Get chat ID: @userinfobot (send /start to get your numeric ID)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==========================================
# DISCORD WEBHOOK (Optional)
# ==========================================
DISCORD_WEBHOOK_URL=

# ==========================================
# EMAIL ALERTS (Optional)
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ==========================================
# AI/LLM SETTINGS (AI-First Architecture)
# ==========================================
# AI Provider: openai, anthropic, groq, ollama, gemini, minimax
AI_PROVIDER=openai

# AI Provider Priority Order (for automatic fallback)
AI_PROVIDER_PRIORITY=openai,anthropic,groq,ollama

# Enable automatic fallback to rule-based when AI fails
ENABLE_AI_FALLBACK=true

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Groq Configuration (Fast free inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Google Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama Configuration (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# MiniMax Configuration (Free tier)
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat

# AI Analysis Settings
ENABLE_AI_ANALYSIS=true
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1000

# AI Caching (Reduce API calls)
CACHE_AI_ANALYSIS=true
AI_CACHE_TTL_MINUTES=60

# Rate Limiting
MAX_AI_CALLS_PER_SCAN=10
AI_TIMEOUT_SECONDS=30

# ==========================================
# ENHANCED ENGINE SETTINGS (v2.0)
# ==========================================
# Market Regime Engine
DETECT_MARKET_REGIME=true
REGIME_TIMEFRAME=4h

# Coin Filter Engine
MAX_FILTERED_COINS=150
MIN_COIN_STRENGTH=-0.5

# Confluence Scoring
MIN_CONFLUENCE_SCORE=6.0

# Position Sizing
BASE_POSITION_SIZE=100
BASE_RISK_PERCENT=2.0

# Optimization Engine
ENABLE_AUTO_OPTIMIZATION=true
MIN_TRADES_FOR_OPTIMIZATION=10

# ==========================================
# SCANNER SETTINGS
# ==========================================
SCAN_INTERVAL_MINUTES=5
MAX_COINS_TO_SCAN=500
MIN_MARKET_CAP_MILLIONS=10
MIN_VOLUME_24H_MILLIONS=1
MIN_SIGNAL_SCORE=7.0
TIMEFRAMES=4h,daily

# ==========================================
# MULTI-TIMEFRAME STRATEGY
# ==========================================
ENABLE_MTF_STRATEGY=true
MTF_TIMEFRAMES=daily,1h,15m
MTF_MIN_CONFIDENCE=7.0

# ==========================================
# PRD SIGNAL ENGINE (v2.1)
# ==========================================
# Enable PRD signal detection (Breakout, Pullback)
ENABLE_PRD_STRATEGY=true
# Timeframes for PRD signals (primary: 4h, 1D)
PRD_TIMEFRAMES=4h,daily
# Minimum AI confidence score (0-100)
PRD_MIN_CONFIDENCE=70.0

# PRD Strategy Parameters
BREAKOUT_VOLUME_MULTIPLIER=1.5
PULLBACK_RSI_LOW=40
PULLBACK_RSI_HIGH=55
MIN_RISK_REWARD=2.0
MAX_RISK_PER_TRADE=0.02

# Market Universe
TOP_COINS_BY_MARKET_CAP=100

# Alert Settings
ALERT_CONFIDENCE_THRESHOLD=70
ALERT_COOLDOWN_HOURS=24

# ==========================================
# LEARNING SYSTEM
# ==========================================
ENABLE_LEARNING=true
SIGNAL_TIMEOUT_DAYS=7
MIN_SIGNALS_FOR_INSIGHTS=20

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log
