# Crypto Scanner Configuration
# Copy this file to .env and fill in your API keys

# ==========================================
# API KEYS (Optional - free tier works without keys)
# ==========================================
# Get free API keys from:
# CoinGecko: https://www.coingecko.com/en/api
# CoinMarketCap: https://coinmarketcap.com/api/
COINGECKO_API_KEY=
CMC_API_KEY=

# Binance (for advanced features)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ==========================================
# TELEGRAM ALERTS
# ==========================================
# Create a bot: @BotFather on Telegram
# Get chat ID: @userinfobot
TELEGRAM_BOT_TOKEN=8368160728:AAH-boeIBXWOLj9MNpYnNut9DhFSoaz-LLE
TELEGRAM_CHAT_ID=647296254

# ==========================================
# DISCORD WEBHOOK
# ==========================================
# Server Settings > Integrations > Create Webhook
DISCORD_WEBHOOK_URL=

# ==========================================
# EMAIL ALERTS (Optional)
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ==========================================
# SCANNER SETTINGS
# ==========================================
SCAN_INTERVAL_MINUTES=5
MAX_COINS_TO_SCAN=500
MIN_MARKET_CAP_MILLIONS=50
MIN_VOLUME_24H_MILLIONS=5
MIN_SIGNAL_SCORE=7.0
TIMEFRAMES=daily,4h,1h,15m

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log
